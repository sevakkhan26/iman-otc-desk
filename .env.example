ADMIN_USERNAME=
# pbkdf2$… from: node scripts/generate-password-hash.mjs '<password>'
# Admin password is env-only (not changeable from the panel).
ADMIN_PASSWORD_HASH=
VIEWER_USERNAME=
# Bootstrap hash for viewer. Admin can rotate viewer password from Settings;
# override is stored in PostgreSQL (app_settings.viewer_auth_override).
# Additional users (viewer/admin) are created from Settings → user management
# and stored in the PostgreSQL users table.
VIEWER_PASSWORD_HASH=
AUTH_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# PostgreSQL (REQUIRED — single source of truth for durable server state)
#
# Local without Docker (embedded PGlite):
#   DATABASE_URL=pglite:.data/pglite
#
# Local/Docker/Ubuntu Postgres:
#   DATABASE_URL=postgres://otc_app:PASSWORD@127.0.0.1:5432/otc_desk
#
# Optional:
#   DATABASE_DIRECT_URL=  (same as DATABASE_URL unless using a pooler)
#   DATABASE_POOL_MAX=10  (bounded connection pool for Next.js)
# -----------------------------------------------------------------------------
DATABASE_URL=
DATABASE_DIRECT_URL=
DATABASE_POOL_MAX=10

# Optional HMAC secret for market API keys (falls back to AUTH_TOKEN_SECRET):
TETHER_API_KEY_HMAC_SECRET=

# -----------------------------------------------------------------------------
# OBSOLETE (runtime no longer uses these — keep only for one-time import):
#   UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   MARKET_SNAPSHOT_STORAGE / MARKET_SNAPSHOT_DATA_*
#   PRICE_ALERTS_STORAGE / PRICE_ALERTS_DATA_*
#   TETHER_API_KEYS_STORAGE / TETHER_API_KEYS_DATA_*
#   VIEWER_AUTH_DATA_FILE / DESK_USERS_DATA_FILE
# Do not delete from production env until PostgreSQL import is verified.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Outbound HTTP(S) proxy for market providers (server-side only, not browser).
#
# Default: only Bonbast + Navasan (matches subdomains e.g. www.navasan.net).
#   OUTBOUND_HTTPS_PROXY=http://user:pass@proxy.example.com:2053
#   PROXY_HOSTS=bonbast.com,navasan.net
#
# Route ALL provider traffic through proxy:
#   PROXY_HOSTS=*
#
# Falls back to HTTPS_PROXY / HTTP_PROXY if OUTBOUND_HTTPS_PROXY is unset.
# -----------------------------------------------------------------------------
OUTBOUND_HTTPS_PROXY=
PROXY_HOSTS=bonbast.com,navasan.net
