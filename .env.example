ADMIN_USERNAME=
# pbkdf2$… from: node scripts/generate-password-hash.mjs '<password>'
# Admin password is env-only (not changeable from the panel).
ADMIN_PASSWORD_HASH=
VIEWER_USERNAME=
# Bootstrap hash for viewer. Admin can rotate viewer password from Settings;
# override is stored on disk (see VIEWER_AUTH_DATA_FILE) and wins over this env value.
# Additional users (viewer/admin) are created from Settings → user management and
# stored in desk-users.json (see DESK_USERS_DATA_FILE).
VIEWER_PASSWORD_HASH=
AUTH_TOKEN_SECRET=

# -----------------------------------------------------------------------------
# Price Alerts storage
# PRICE_ALERTS_STORAGE = file | upstash | none
#
# Docker production (required explicit settings):
#   PRICE_ALERTS_STORAGE=file
#   PRICE_ALERTS_DATA_DIR=/app/data/price-alerts
#   PRICE_ALERTS_DATA_FILE=/app/data/price-alerts/price-alerts.json
#   (compose mounts named volume iman-otc-alerts-data at DATA_DIR)
#   Viewer password override defaults to ${PRICE_ALERTS_DATA_DIR}/viewer-auth.json
#   Managed users file defaults to ${PRICE_ALERTS_DATA_DIR}/desk-users.json
#
# Vercel:
#   Prefer Upstash REST vars; never uses local file storage.
#   If Upstash is missing, storage mode is "none" (writes return 503).
#
# Local development:
#   Defaults to file under .data/price-alerts when unset.
# -----------------------------------------------------------------------------
PRICE_ALERTS_STORAGE=
PRICE_ALERTS_DATA_DIR=
PRICE_ALERTS_DATA_FILE=
# Optional explicit path for viewer password override JSON (hash + session epoch).
VIEWER_AUTH_DATA_FILE=
# Optional explicit path for managed users JSON (admin-created accounts).
DESK_USERS_DATA_FILE=

# Optional Redis REST (Vercel or multi-replica). Not required for Docker file mode.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# -----------------------------------------------------------------------------
# Outbound HTTP(S) proxy for market providers (server-side only, not browser).
#
# Default: only Bonbast + Navasan (matches subdomains e.g. www.navasan.net).
#   OUTBOUND_HTTPS_PROXY=http://user:pass@proxy.example.com:2053
#   PROXY_HOSTS=bonbast.com,navasan.net
#
# Route ALL provider traffic through proxy:
#   PROXY_HOSTS=*
#
# Falls back to HTTPS_PROXY / HTTP_PROXY if OUTBOUND_HTTPS_PROXY is unset.
# -----------------------------------------------------------------------------
OUTBOUND_HTTPS_PROXY=
PROXY_HOSTS=bonbast.com,navasan.net
